{
  "name": "rutter",
  "version": "0.0.0",
  "description": "Framework-agnostic, lightweight router.",
  "keywords": [
    "framework-agnostic",
    "history-api",
    "router",
    "type-safe",
    "urlpattern"
  ],
  "license": "MIT",
  "author": "Thiha Thit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thihathit/rutter.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "bundle": "tsup",
    "preview": "vite preview",
    "postinstall": "bash ./.githooks/install.sh",
    "pkg:prepare": "tsx --tsconfig ./tsconfig.json ./scripts/build-package-info.ts",
    "lint:code": "oxlint",
    "lint:type": "tsc",
    "lint:package": "publint",
    "lint:commit": "commitlint --edit $1",
    "format": "oxfmt"
  },
  "dependencies": {
    "@preact/signals-core": "^1.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@types/lodash-es": "^4.17.7",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "lodash-es": "^4.18.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "pretty-quick": "^4.2.2",
    "publint": "^0.3.21",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "urlpattern-polyfill": "^10.1.0",
    "vite": "^8.0.14",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.4.0"
  },
  "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a"
}
